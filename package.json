{
  "name": "anton.computer",
  "private": true,
  "version": "1.0.44",
  "description": "Your personal cloud computer. Open source. AI-native. Self-hosted.",
  "scripts": {
    "agent:dev": "pnpm --filter @anton/agent-server dev",
    "agent:build": "pnpm --filter @anton/protocol build && pnpm --filter @anton/logger build && pnpm --filter @anton/agent-config build && pnpm --filter @anton/agent-core build && pnpm --filter @anton/agent-server build && pnpm --filter @anton/agent build",
    "cli:dev": "pnpm --filter @anton/cli dev",
    "cli:build": "pnpm --filter @anton/cli build",
    "desktop:dev": "pnpm --filter @anton/desktop dev",
    "desktop:app": "pnpm --filter @anton/desktop tauri dev",
    "desktop:build": "pnpm --filter @anton/desktop build",
    "protocol:build": "pnpm --filter @anton/protocol build",
    "build": "pnpm -r build",
    "clean": "pnpm -r exec rm -rf dist",
    "lint": "biome lint ./packages",
    "format": "biome format ./packages",
    "format:fix": "biome format --write ./packages",
    "check": "biome check ./packages",
    "check:fix": "biome check --write ./packages",
    "typecheck": "pnpm -r typecheck",
    "typecheck:agent": "pnpm --filter @anton/agent typecheck",
    "typecheck:cli": "pnpm --filter @anton/cli typecheck",
    "typecheck:desktop": "pnpm --filter @anton/desktop typecheck",
    "typecheck:protocol": "pnpm --filter @anton/protocol typecheck",
    "verify": "pnpm typecheck && pnpm check",
    "deploy": "./deploy/sync.sh",
    "dev": "pnpm protocol:build && concurrently \"pnpm agent:dev\" \"pnpm desktop:dev\"",
    "dev:local": "ANTON_LOCAL=1 pnpm dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "esbuild": "^0.27.4"
  },
  "keywords": [
    "ai",
    "agent",
    "cloud",
    "computer",
    "self-hosted",
    "vps"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/OmGuptaIND/computer"
  }
}
