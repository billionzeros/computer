{
  "$schema": "https://raw.githubusercontent.com/nicedoctor/tauri/v2/core/tauri-config-schema.json",
  "productName": "anton.computer",
  "version": "1.0.31",
  "identifier": "computer.anton.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "anton.computer",
        "width": 900,
        "height": 700,
        "minWidth": 760,
        "minHeight": 400,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMwMEJENjExRUQzQjEzNgpSV1Eyc2RNZVliMEFBeEhtZVFwaVVXOVB2a2RhNVRGWlE3bk81VGZxN3hnSXdtaWtLMklyYmtlNgo=",
      "endpoints": [
        "https://github.com/OmGuptaIND/computer/releases/latest/download/latest.json"
      ]
    }
  }
}
